# Environment variables for the moaxy proxy.
#
# Copy this file to `.env` (which is gitignored) and replace the placeholder
# values with your real secrets. Never commit the populated `.env` file.

# OpenRouter (https://openrouter.ai) API key used by `OpenRouterAdapter`.
# The adapter reads this at construction time; the proxy refuses to start
# when the variable is unset. The key is never logged in plain text.
OPENROUTER_API_KEY=sk-or-v1-replace-me-with-your-real-openrouter-api-key
